# ==========================================
# TaxFlow AI - Environment Variables Example
# ==========================================
# Copy this file to .env and configure your values
# DO NOT commit .env to version control!
# ==========================================

# ==========================================
# APPLICATION CONFIGURATION
# ==========================================

# Application environment
NODE_ENV=development
DEBUG=false

# Server ports
PORT=3000
API_PORT=3001

# Base URL for the application
BASE_URL=http://localhost:3000

# ==========================================
# DATABASE CONFIGURATION
# ==========================================

# SQLite (development) - path relative to project root
DATABASE_URL=sqlite:///./taxflow.db

# PostgreSQL (production) - uncomment and configure for production
# DATABASE_URL=postgresql://taxflow:your_password@postgres:5432/taxflow
# DATABASE_POOL_SIZE=20
# DATABASE_SSL=true

# ==========================================
# OPENAI CONFIGURATION
# ==========================================

# OpenAI API Key - get from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI Model to use
OPENAI_MODEL=gpt-4o

# OpenAI Organization ID (optional)
# OPENAI_ORG_ID=your_organization_id

# Max tokens for responses
OPENAI_MAX_TOKENS=4000

# Temperature for responses (0-2)
OPENAI_TEMPERATURE=0.7

# ==========================================
# VECTOR DATABASE (RAG)
# ==========================================

# pgvector connection (production)
# PGHOST=postgres
# PGPORT=5432
# PGUSER=taxflow
# PGPASSWORD=your_password
# PGDATABASE=taxflow_vectors

# Embedding model
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ==========================================
# AUTHENTICATION
# ==========================================

# JWT Secret - generate a secure random string
JWT_SECRET=your_super_secure_jwt_secret_key_here_change_in_production

# JWT Expiration
JWT_EXPIRY=7d

# ==========================================
# FILE STORAGE
# ==========================================

# Upload directory (relative to project root)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800  # 50MB

# Allowed file extensions (comma-separated)
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png,doc,docx,xls,xlsx,csv

# ==========================================
# CORS CONFIGURATION
# ==========================================

# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ==========================================
# LOGGING & OBSERVABILITY
# ==========================================

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Enable structured logging
STRUCTURED_LOGGING=true

# LangSmith Configuration (optional - for tracing)
# LANGSMITH_API_KEY=your_langsmith_api_key
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=taxflow-ai

# ==========================================
# RATE LIMITING
# ==========================================

# API rate limit (requests per minute)
RATE_LIMIT=60

# Workflow rate limit
WORKFLOW_RATE_LIMIT=10

# ==========================================
# REDIS (Production Cache & Session)
# ==========================================

# Redis connection (optional - for production)
# REDIS_URL=redis://redis:6379
# REDIS_PASSWORD=your_redis_password

# ==========================================
# EMAIL (Optional - for notifications)
# ==========================================

# SMTP Configuration (optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM=TaxFlow AI <noreply@taxflow.ai>

# ==========================================
# SECURITY
# ==========================================

# Enable HTTPS in production
# FORCE_HTTPS=true

# Session secret
SESSION_SECRET=your_session_secret_here_change_in_production

# ==========================================
# FEATURE FLAGS
# ==========================================

# Enable experimental features
ENABLE_EXPERIMENTAL_FEATURES=false

# Enable AI chat
ENABLE_CHAT=true

# Enable workflow automation
ENABLE_WORKFLOWS=true

# Enable RAG knowledge base
ENABLE_RAG=true
